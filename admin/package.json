{
  "name": "medusa-admin-4wd-tours",
  "version": "1.0.0",
  "description": "Standalone Medusa Admin Dashboard for 4WD Tours - Deployed on Vercel",
  "private": true,
  "author": "4WD Tours Australia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/med-usa-4wd"
  },
  "scripts": {
    "build": "echo 'Admin built via medusa build --admin-only in parent project'",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
