# Medusa Admin - Environment Variables Template
# Copy this file to .env.local for local testing
# For Vercel deployment, set these in Vercel dashboard or CLI

# Backend API URL (Railway)
# This is where your Medusa backend is hosted
MEDUSA_ADMIN_BACKEND_URL=https://4wd-tours-production.up.railway.app

# Node Environment
NODE_ENV=production

# IMPORTANT NOTES:
# 1. This admin connects to the Railway backend API
# 2. Ensure Railway CORS includes your Vercel admin domain
# 3. Backend must have ADMIN_CORS and AUTH_CORS configured
# 4. No secrets needed in admin - authentication happens via backend
